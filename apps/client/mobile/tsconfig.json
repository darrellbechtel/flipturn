{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "types": ["react", "react-native", "node"],
    "jsx": "react-native",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"]
  },
  "include": [
    "app/**/*",
    "api/**/*",
    "auth/**/*",
    "components/**/*",
    "lib/**/*",
    "theme/**/*",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": ["dist", "node_modules", "tests", ".expo"]
}
