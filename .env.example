# Local dev — copy to .env and adjust as needed
# Ports are intentionally non-default (55432, 56379) so the dev stack can run
# alongside any host-installed postgres/redis without conflict.
DATABASE_URL="postgresql://flipturn:flipturn_dev@localhost:55432/flipturn?schema=public"
REDIS_URL="redis://localhost:56379"

# Workers (apps/server/workers)
SENTRY_DSN=                          # optional; leave blank to disable Sentry
LOG_LEVEL=debug                      # one of: fatal/error/warn/info/debug/trace
SCRAPE_USER_AGENT="FlipTurnBot/0.1 (+https://flipturn.app/bot; contact@flipturn.app)"
SCRAPE_RATE_LIMIT_MS=5000
SCRAPE_DAILY_HOST_BUDGET=500
ARCHIVE_DIR=./data/raw

# API (apps/api)
PORT=3000
BASE_URL="http://localhost:3000"
RESEND_API_KEY=                      # leave blank in dev to use the InMemory fake
EMAIL_FROM="Flip Turn <noreply@flipturn.app>"
MOBILE_DEEP_LINK_BASE="flipturn://auth"
